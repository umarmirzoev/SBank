# --- Production Environment Variables ---
# Fill these in .env.prod for production deployment

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production

# Database Connection String
# Example for external DB: Host=1.2.3.4;Database=somonibank;Username=postgres;Password=mypassword
ConnectionStrings__Default=Host=YOUR_DB_HOST;Database=YOUR_DB_NAME;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD

# JWT Security
# Must be at least 32 characters long
Jwt__Secret=YOUR_SECURE_JWT_SECRET_KEY_MIN_32_CHARS

# Logging Level (optional)
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning

# Development Test User (If you need seed data, though usually disabled in Prod)
# DevelopmentTestUser__Phone=+992979117007
# DevelopmentTestUser__Password=mysecurepassword
